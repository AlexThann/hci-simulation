          {
            "form_id": "intervention_form",
            "fields": [
              "device",
              "alarm_type",
              "action",
              "flow_rate_recheck"
            ]
          }
        ]
      },
      "feedback_blocked": "Πρέπει να τεκμηριώσεις το alarm και την αποκατάσταση ροής.",
