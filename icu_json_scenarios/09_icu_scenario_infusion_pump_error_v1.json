      "timeout": {
        "seconds": 30,
        "on_timeout_effects": {
          "vitals_update": {
            "bp": "86/52",
            "bp_systolic": 86,
            "bp_diastolic": 52,
            "hr": 128
          },
          "score_delta": -10,
          "toast": "Καθυστέρηση! Η πίεση έπεσε σε 86/52."
        },
        "next_node_id": "n3_confirm_problem"
      }
    },
    {
      "id": "n3_confirm_problem",
      "type": "decision",
      "text": "Το πρόβλημα αντλίας επιβεβαιώνεται. Τι ελέγχεις;",
      "options": [
        {
          "id": "opt_check_line",
          "label": "Έλεγχος γραμμής και σύνδεσης",
          "target_hotspot": "hs_infusion_pump",
          "effects": {
            "score_delta": 10,
            "state_update": {
              "flags.line_checked": true
            },
            "toast": "Η γραμμή έχει κάμψη και η ροή έχει σταματήσει."
          },
          "next_node_id": "n4_intervention"
        },
        {
          "id": "opt_check_ehr",
          "label": "Έλεγχος ρυθμού έγχυσης στο EHR",
          "target_hotspot": "hs_ehr",
          "effects": {
            "score_delta": 5,
            "toast": "Βρίσκεις τον προβλεπόμενο ρυθμό έγχυσης."
          },
          "next_node_id": "n4_intervention"
        },
        {
          "id": "opt_wait",
          "label": "Αναμονή για αυτόματη διόρθωση",
          "target_hotspot": "hs_monitor",
          "effects": {
            "score_delta": -20,
            "vitals_update": {
              "bp": "82/50",
              "bp_systolic": 82,
              "hr": 132
            },
            "toast": "Λάθος. Η ροή δεν αποκαθίσταται."
          },
          "next_node_id": "n4_intervention"
        }
      ]
    },
    {
      "id": "n4_intervention",
      "type": "decision",
      "text": "Ποια παρέμβαση εκτελείς;",
      "options": [
        {
          "id": "opt_restart_pump",
          "label": "Διόρθωση γραμμής και επανεκκίνηση αντλίας",
          "target_hotspot": "hs_infusion_pump",
          "effects": {
            "score_delta": 20,
            "state_update": {
              "flags.pump_restarted": true
            },
            "vitals_update": {
              "bp": "105/66",
              "bp_systolic": 105,
              "bp_diastolic": 66,
              "hr": 104
            },
            "toast": "Η ροή αποκαταστάθηκε και τα ζωτικά βελτιώνονται."
          },
          "next_node_id": "n5_gate_documentation_1"
        },
        {
          "id": "opt_call_biomed",
          "label": "Κλήση βοήθειας χωρίς έλεγχο γραμμής",
          "target_hotspot": "hs_call",
          "effects": {
            "score_delta": 5,
            "state_update": {
              "flags.escalation_complete": true
            },
            "toast": "Ζητήθηκε βοήθεια, αλλά ο αρχικός έλεγχος γραμμής ήταν απαραίτητος."
          },
          "next_node_id": "n5_gate_documentation_1"
        },
        {
          "id": "opt_no_action",
          "label": "Καμία παρέμβαση",
          "target_hotspot": "hs_monitor",
          "effects": {
            "score_delta": -25,
            "vitals_update": {
              "bp": "78/48",
              "bp_systolic": 78,
              "hr": 138
            },
            "toast": "Κρίσιμο λάθος. Τα ζωτικά χειροτερεύουν."
          },
          "next_node_id": "n5_gate_documentation_1"
        }
      ]
    },
    {
      "id": "n5_gate_documentation_1",
      "type": "gate",
      "text": "GATE: Τεκμηρίωση σφάλματος αντλίας.",
      "description": "Η ροή μπλοκάρει μέχρι να συμπληρωθούν τα απαιτούμενα πεδία στο EHR.",
      "gate_requirements": {
        "target_hotspot": "hs_ehr",
        "required_forms": [
          {
            "form_id": "assessment_form",
            "fields": [
              "observation",
              "bp_value"
            ]
