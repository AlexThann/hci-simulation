      "effects_on_pass": {
        "state_update": {
          "flags.documentation_1_complete": true
        },
        "score_delta": 10
      },
      "next_node_id": "n6_reassessment"
    },
    {
      "id": "n6_reassessment",
      "type": "message",
      "text": "5 λεπτά αργότερα... Η αντλία λειτουργεί κανονικά και η BP είναι 105/66.",
