  "hotspots": [
    {
      "id": "hs_monitor",
      "label": "Μόνιτορ Ζωτικών Λειτουργιών"
    },
    {
      "id": "hs_patient",
      "label": "Ασθενής / Κλίνη"
    },
    {
      "id": "hs_infusion_pump",
      "label": "Αντλία Έγχυσης"
    },
    {
      "id": "hs_ehr",
      "label": "Τερματικό EHR / e-Health"
    },
    {
      "id": "hs_call",
      "label": "Κουμπί Κλήσης"
    }
  ],
  "ehr_config": {
    "forms": {
      "assessment_form": {
        "title": "Κλινική Αξιολόγηση",
        "fields": [
          "observation",
          "consciousness",
          "bp_value",
          "skin_color"
        ]
      },
      "intervention_form": {
        "title": "Παρέμβαση Αντλίας Έγχυσης",
        "fields": [
          "device",
          "alarm_type",
          "action",
          "flow_rate_recheck"
        ]
      },
      "communication_log": {
        "title": "Ημερολόγιο Επικοινωνίας",
        "fields": [
          "recipient",
          "reason",
          "outcome"
        ]
      }
    }
  },
  "rules": {
    "global_rules": [
      {
        "id": "rule_low_bp_warning",
        "condition": {
          "vitals.bp_systolic": {
            "lt": 95
          }
        },
        "effects": [
          {
            "type": "ui_visual",
            "target": "hs_monitor",
            "state": "yellow_warning"
          },
          {
            "type": "ui_toast",
            "style": "warning",
            "message": "Προειδοποίηση: Η πίεση είναι χαμηλή."
          }
        ]
      }
    ]
  },
  "nodes": [
    {
      "id": "n1_start",
      "type": "message",
      "text": "Η αντλία έγχυσης χτυπάει alarm. Η BP είναι 92/58 και η HR 118.",
      "next_node_id": "n2_initial_decision"
    },
    {
      "id": "n2_initial_decision",
      "type": "decision",
      "text": "Ποια είναι η πρώτη σου ενέργεια;",
      "options": [
        {
          "id": "opt_check_pump",
          "label": "Άμεσος έλεγχος αντλίας",
          "target_hotspot": "hs_infusion_pump",
          "effects": {
            "score_delta": 10,
            "state_update": {
              "flags.pump_checked": true
            },
            "toast": "Η αντλία εμφανίζει alarm απόφραξης/παύσης ροής."
          },
          "next_node_id": "n3_confirm_problem"
        },
        {
          "id": "opt_assess",
          "label": "Αξιολόγηση ασθενούς",
          "target_hotspot": "hs_patient",
          "effects": {
            "score_delta": 10,
            "state_update": {
              "flags.assessment_complete": true
            },
            "toast": "Ο ασθενής είναι ωχρός αλλά συνεργάσιμος."
          },
          "next_node_id": "n3_confirm_problem"
        },
        {
          "id": "opt_ignore",
          "label": "Σίγαση alarm και αναμονή",
          "target_hotspot": "hs_infusion_pump",
          "effects": {
            "score_delta": -10,
            "toast": "Η σίγαση δεν αποκαθιστά τη ροή."
          },
          "next_node_id": "n3_confirm_problem"
