      "next_node_id": "n9_end_scenario"
    },
    {
      "id": "n9_end_scenario",
      "type": "end",
      "text": "Το σενάριο σφάλματος αντλίας ολοκληρώθηκε.",
      "debrief_config": {
        "show_score": true,
        "show_decision_path": true,
        "highlight_missed_docs": true,
        "export_log": true
      }
