      "documentation_2_complete": false
    },
    "vitals": {
      "hr": 118,
      "spo2": 96,
      "rr": 22,
      "bp": "92/58",
      "bp_systolic": 92,
      "bp_diastolic": 58,
      "temp": 37.0
    },
    "ui": {
      "active_hotspots": [
        "hs_monitor",
        "hs_patient",
        "hs_infusion_pump",
        "hs_ehr",
        "hs_call"
