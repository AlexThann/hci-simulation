            "fields": [
              "recipient",
              "reason",
              "outcome"
            ]
          }
        ]
      },
      "feedback_blocked": "Εκκρεμεί η καταγραφή επικοινωνίας στο EHR.",
      "feedback_success": "Η επικοινωνία καταγράφηκε.",
      "effects_on_pass": {
        "state_update": {
          "flags.documentation_2_complete": true
        },
        "score_delta": 5
