{
  "schema_version": "1.0",
  "scenario_meta": {
    "id": "icu_scenario_infusion_pump_error_v1",
    "title": "ΜΕΘ: Σφάλμα στην Αντλία Έγχυσης",
    "description": "Σενάριο alarm αντλίας έγχυσης με έλεγχο συσκευής, επανεκκίνηση ροής και τεκμηρίωση.",
    "estimated_duration_minutes": 8,
    "difficulty": "Intermediate",
    "learning_goals": [
