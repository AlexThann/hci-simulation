          {
            "form_id": "intervention_form",
            "fields": [
              "action",
              "warming_device",
              "temperature_recheck"
            ]
          }
        ]
      },
      "feedback_blocked": "Πρέπει να τεκμηριώσεις θερμοκρασία και θερμαντικά μέτρα.",
      "feedback_success": "Η τεκμηρίωση αποθηκεύτηκε.",
