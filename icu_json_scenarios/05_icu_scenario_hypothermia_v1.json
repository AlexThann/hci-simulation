        "title": "Ημερολόγιο Επικοινωνίας",
        "fields": [
          "recipient",
          "reason",
          "outcome"
        ]
      }
    }
  },
  "rules": {
    "global_rules": [
      {
        "id": "rule_low_temp_alarm",
        "condition": {
          "vitals.temp": {
            "lt": 35.5
          }
        },
        "effects": [
          {
            "type": "ui_visual",
            "target": "hs_monitor",
            "state": "blue_warning"
          },
          {
            "type": "ui_toast",
            "style": "warning",
            "message": "ΠΡΟΕΙΔΟΠΟΙΗΣΗ: Θερμοκρασία < 35.5°C"
          }
        ]
      }
    ]
  },
  "nodes": [
    {
      "id": "n1_start",
      "type": "message",
      "text": "Μετά από επέμβαση, ο ασθενής εμφανίζει θερμοκρασία 35.0°C και HR 58. Το μόνιτορ εμφανίζει προειδοποίηση.",
      "next_node_id": "n2_initial_decision"
    },
    {
      "id": "n2_initial_decision",
      "type": "decision",
      "text": "Ποια είναι η πρώτη σου ενέργεια;",
      "options": [
        {
          "id": "opt_assess",
          "label": "Αξιολόγηση ασθενούς",
          "target_hotspot": "hs_patient",
          "effects": {
            "score_delta": 10,
            "state_update": {
              "flags.assessment_complete": true
            },
            "toast": "Ο ασθενής είναι κρύος στην αφή και τρέμει ελαφρά."
          },
          "next_node_id": "n3_confirm_problem"
        },
        {
          "id": "opt_monitor",
          "label": "Επιβεβαίωση θερμοκρασίας στο μόνιτορ",
          "target_hotspot": "hs_monitor",
          "effects": {
            "score_delta": 5,
            "state_update": {
              "flags.temperature_confirmed": true
            },
            "toast": "Η θερμοκρασία παραμένει χαμηλή."
          },
          "next_node_id": "n3_confirm_problem"
        },
        {
          "id": "opt_call_first",
          "label": "Κλήση ιατρού χωρίς αρχική αξιολόγηση",
          "target_hotspot": "hs_call",
