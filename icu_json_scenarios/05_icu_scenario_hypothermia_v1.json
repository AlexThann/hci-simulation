{
  "schema_version": "1.0",
  "scenario_meta": {
    "id": "icu_scenario_hypothermia_v1",
    "title": "ΜΕΘ: Υποθερμία μετά από Επέμβαση",
    "description": "Σενάριο χαμηλής θερμοκρασίας σε ασθενή μετά από επέμβαση με χρήση θερμαντικών μέτρων.",
    "estimated_duration_minutes": 8,
    "difficulty": "Intermediate",
    "learning_goals": [
      "Αναγνώριση υποθερμίας",
      "Χρήση θερμαντικής κουβέρτας",
      "Επανέλεγχος θερμοκρασίας",
      "Τεκμηρίωση στο EHR"
    ]
  },
  "initial_state": {
