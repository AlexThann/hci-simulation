            "score_delta": 10,
            "toast": "Ο εφημερεύων ιατρός ενημερώθηκε."
          },
          "next_node_id": "n8_gate_documentation_2"
        },
        {
          "id": "opt_monitor_only",
          "label": "Συνέχιση παρακολούθησης χωρίς κλιμάκωση",
          "target_hotspot": "hs_monitor",
          "effects": {
            "score_delta": -5,
            "toast": "Συνεχίζεις την παρακολούθηση, αλλά η κλιμάκωση θα ήταν ασφαλέστερη επιλογή."
          },
          "next_node_id": "n9_end_scenario"
        }
      ]
    },
    {
      "id": "n8_gate_documentation_2",
      "type": "gate",
      "text": "GATE: Καταγραφή επικοινωνίας.",
