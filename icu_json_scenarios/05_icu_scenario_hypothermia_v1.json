            "toast": "Η κλήση έγινε, αλλά πρώτα χρειάζεται αξιολόγηση και ασφαλής παρέμβαση."
          },
          "next_node_id": "n3_confirm_problem"
        }
      ],
      "timeout": {
        "seconds": 30,
        "on_timeout_effects": {
          "vitals_update": {
            "temp": 34.7,
            "hr": 54
          },
          "score_delta": -10,
          "toast": "Καθυστέρηση! Η θερμοκρασία έπεσε στους 34.7°C."
        },
        "next_node_id": "n3_confirm_problem"
      }
    },
    {
      "id": "n3_confirm_problem",
      "type": "decision",
      "text": "Η υποθερμία επιβεβαιώνεται. Ποιο στοιχείο ελέγχεις;",
      "options": [
        {
          "id": "opt_check_blanket",
          "label": "Έλεγχος διαθέσιμης θερμαντικής κουβέρτας",
          "target_hotspot": "hs_warming_blanket",
          "effects": {
            "score_delta": 10,
            "toast": "Η θερμαντική κουβέρτα είναι διαθέσιμη."
          },
          "next_node_id": "n4_intervention"
        },
        {
          "id": "opt_reassess_skin",
          "label": "Έλεγχος δέρματος και άνεσης ασθενούς",
          "target_hotspot": "hs_patient",
          "effects": {
            "score_delta": 5,
            "toast": "Ο ασθενής είναι ψυχρός και χρειάζεται θέρμανση."
          },
          "next_node_id": "n4_intervention"
        },
        {
          "id": "opt_wait",
          "label": "Αναμονή",
          "target_hotspot": "hs_monitor",
          "effects": {
            "score_delta": -20,
            "vitals_update": {
              "temp": 34.5,
              "hr": 52
            },
            "toast": "Λάθος. Η θερμοκρασία συνεχίζει να πέφτει."
          },
          "next_node_id": "n4_intervention"
        }
      ]
    },
    {
      "id": "n4_intervention",
      "type": "decision",
      "text": "Ποια παρέμβαση ξεκινάς;",
      "options": [
        {
          "id": "opt_start_warming",
          "label": "Ενεργοποίηση θερμαντικής κουβέρτας και επανέλεγχος",
          "target_hotspot": "hs_warming_blanket",
          "effects": {
            "score_delta": 20,
            "state_update": {
              "flags.warming_started": true
            },
            "vitals_update": {
              "temp": 36.0,
              "hr": 65
            },
            "toast": "Η θέρμανση ξεκίνησε και η θερμοκρασία βελτιώνεται."
          },
          "next_node_id": "n5_gate_documentation_1"
        },
        {
          "id": "opt_extra_blanket_only",
          "label": "Κάλυψη ασθενούς χωρίς ενεργό επανέλεγχο",
          "target_hotspot": "hs_patient",
          "effects": {
            "score_delta": 5,
            "toast": "Η άνεση βελτιώνεται, αλλά χρειάζεται επανέλεγχος θερμοκρασίας."
          },
          "next_node_id": "n5_gate_documentation_1"
        },
        {
          "id": "opt_no_intervention",
          "label": "Καμία παρέμβαση",
          "target_hotspot": "hs_monitor",
          "effects": {
            "score_delta": -25,
            "vitals_update": {
              "temp": 34.3,
              "hr": 50
            },
            "toast": "Κρίσιμο λάθος. Η υποθερμία επιδεινώνεται."
          },
          "next_node_id": "n5_gate_documentation_1"
        }
      ]
    },
    {
      "id": "n5_gate_documentation_1",
      "type": "gate",
      "text": "GATE: Τεκμηρίωση υποθερμίας και θερμαντικών μέτρων.",
      "description": "Η ροή μπλοκάρει μέχρι να συμπληρωθούν τα απαιτούμενα πεδία στο EHR.",
      "gate_requirements": {
        "target_hotspot": "hs_ehr",
        "required_forms": [
          {
            "form_id": "assessment_form",
            "fields": [
              "observation",
              "temperature_value"
            ]
