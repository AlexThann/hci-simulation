      "temperature_confirmed": false,
      "warming_started": false,
      "documentation_1_complete": false,
      "escalation_complete": false,
      "documentation_2_complete": false
    },
    "vitals": {
      "hr": 58,
      "spo2": 97,
      "rr": 16,
      "bp": "110/70",
      "temp": 35.0
    },
    "ui": {
      "active_hotspots": [
        "hs_monitor",
        "hs_patient",
        "hs_warming_blanket",
        "hs_ehr",
        "hs_call"
      ],
      "monitor_alert": true
    }
  },
  "hotspots": [
    {
      "id": "hs_monitor",
      "label": "Μόνιτορ Ζωτικών Λειτουργιών"
    },
    {
      "id": "hs_patient",
      "label": "Ασθενής / Κλίνη"
    },
    {
      "id": "hs_warming_blanket",
      "label": "Θερμαντική Κουβέρτα"
    },
    {
      "id": "hs_ehr",
      "label": "Τερματικό EHR / e-Health"
    },
    {
      "id": "hs_call",
      "label": "Κουμπί Κλήσης"
    }
  ],
  "ehr_config": {
    "forms": {
      "assessment_form": {
        "title": "Κλινική Αξιολόγηση",
        "fields": [
          "observation",
          "consciousness",
          "temperature_value",
          "skin_condition"
        ]
      },
      "intervention_form": {
        "title": "Παρέμβαση Υποθερμίας",
        "fields": [
          "action",
          "warming_device",
          "temperature_recheck"
        ]
      },
