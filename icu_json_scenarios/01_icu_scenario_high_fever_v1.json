            "toast": "Βλέπεις αύξηση θερμοκρασίας και HR τα τελευταία 10 λεπτά."
          },
          "next_node_id": "n3_confirm_problem"
        },
        {
          "id": "opt_open_ehr_first",
          "label": "Άνοιγμα EHR πριν την αξιολόγηση",
          "target_hotspot": "hs_ehr",
          "effects": {
            "score_delta": -5,
            "toast": "Το EHR είναι χρήσιμο, αλλά πρώτα απαιτείται άμεση αξιολόγηση του ασθενούς."
          },
          "next_node_id": "n3_confirm_problem"
        }
      ],
      "timeout": {
        "seconds": 30,
        "on_timeout_effects": {
          "vitals_update": {
            "temp": 40.0,
