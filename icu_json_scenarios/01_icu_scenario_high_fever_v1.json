{
  "schema_version": "1.0",
  "scenario_meta": {
    "id": "icu_scenario_high_fever_v1",
    "title": "ΜΕΘ: Διαχείριση Υψηλού Πυρετού",
    "description": "Σενάριο διαχείρισης ασθενούς στη ΜΕΘ με υψηλό πυρετό, ταχυκαρδία, βασική παρέμβαση, κλιμάκωση και υποχρεωτική τεκμηρίωση στο EHR.",
    "estimated_duration_minutes": 8,
    "difficulty": "Intermediate",
    "learning_goals": [
      "Αναγνώριση συναγερμού υψηλής θερμοκρασίας",
      "Άμεση αξιολόγηση ασθενούς",
      "Χρήση EHR για τεκμηρίωση παρέμβασης",
      "Κλιμάκωση σε ιατρό μετά την επανεκτίμηση"
    ]
  },
  "initial_state": {
    "time_elapsed": 0,
    "current_score": 100,
    "flags": {
      "assessment_complete": false,
      "fever_confirmed": false,
      "intervention_started": false,
      "documentation_1_complete": false,
      "escalation_complete": false,
      "documentation_2_complete": false
    },
    "vitals": {
      "hr": 122,
      "spo2": 96,
      "rr": 24,
      "bp": "118/76",
      "temp": 39.6
    },
    "ui": {
      "active_hotspots": [
        "hs_monitor",
        "hs_patient",
        "hs_medication_cart",
        "hs_ehr",
        "hs_call"
      ],
      "monitor_alert": true
    }
  },
  "hotspots": [
    {
      "id": "hs_monitor",
      "label": "Μόνιτορ Ζωτικών Λειτουργιών"
    },
    {
      "id": "hs_patient",
      "label": "Ασθενής / Κλίνη"
    },
    {
      "id": "hs_medication_cart",
      "label": "Τροχήλατο Φαρμάκων"
    },
    {
      "id": "hs_ehr",
      "label": "Τερματικό EHR / e-Health"
    },
    {
      "id": "hs_call",
      "label": "Κουμπί Κλήσης"
    }
  ],
  "ehr_config": {
    "forms": {
      "assessment_form": {
        "title": "Κλινική Αξιολόγηση",
        "fields": [
          "observation",
          "skin_condition",
          "consciousness",
          "temperature_value"
        ]
      },
      "intervention_form": {
        "title": "Παρέμβαση Πυρετού",
        "fields": [
          "action",
          "cooling_measures",
          "medication_checked",
          "temperature_recheck"
        ]
      },
      "communication_log": {
        "title": "Ημερολόγιο Επικοινωνίας",
        "fields": [
          "recipient",
          "reason",
          "outcome"
        ]
      }
    }
  },
  "rules": {
    "global_rules": [
      {
        "id": "rule_high_fever_alarm",
        "condition": {
          "vitals.temp": {
            "gt": 39.0
          }
        },
        "effects": [
          {
            "type": "ui_visual",
            "target": "hs_monitor",
            "state": "blinking_red"
          },
          {
            "type": "ui_toast",
            "style": "danger",
            "message": "ΣΥΝΑΓΕΡΜΟΣ: Θερμοκρασία > 39.0°C"
          }
        ]
      },
      {
        "id": "rule_tachycardia_warning",
        "condition": {
          "vitals.hr": {
            "gt": 120
          }
        },
        "effects": [
          {
            "type": "ui_visual",
            "target": "hs_monitor",
            "state": "yellow_warning"
          },
          {
            "type": "ui_toast",
            "style": "warning",
            "message": "Προειδοποίηση: Αυξημένη καρδιακή συχνότητα."
          }
        ]
      }
    ]
  },
  "nodes": [
    {
      "id": "n1_start",
      "type": "message",
      "text": "Βρίσκεστε στη ΜΕΘ. Το μόνιτορ χτυπάει. Ο ασθενής στην κλίνη 3 είναι κατακόκκινος και ιδρωμένος. Θερμοκρασία: 39.6°C, HR: 122.",
      "next_node_id": "n2_initial_decision"
    },
    {
      "id": "n2_initial_decision",
      "type": "decision",
      "text": "Ποια είναι η πρώτη σου ενέργεια;",
      "options": [
        {
          "id": "opt_assess_patient",
          "label": "Άμεση αξιολόγηση ασθενούς",
          "target_hotspot": "hs_patient",
          "effects": {
            "score_delta": 10,
            "state_update": {
              "flags.assessment_complete": true
            },
            "toast": "Ο ασθενής είναι ιδρωμένος, θερμός στην αφή και απαντά αργά."
          },
          "next_node_id": "n3_confirm_problem"
        },
        {
          "id": "opt_check_monitor",
          "label": "Έλεγχος τάσης ζωτικών στο μόνιτορ",
